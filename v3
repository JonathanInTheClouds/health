auto makeBuffer = [](uint32_t magic,
                     uint32_t sequence_id,
                     uint32_t source_id,
                     const char* payloadStr)
    -> std::vector<uint8_t>
{
    // PreMessage layout (must match your struct exactly)
    struct Pre {
        uint32_t magic;
        uint16_t version;
        uint16_t flags;
        uint32_t record_count;
        uint32_t record_size;
        uint64_t payload_bytes;
    } __attribute__((packed));

    // MessageHeader layout (must match your struct exactly)
    struct Hdr {
        uint32_t sequence_id;
        uint32_t source_id;
        uint64_t timestamp_ns;
        uint16_t encoding;
        uint16_t checksum;
    } __attribute__((packed));

    size_t payloadSize = std::strlen(payloadStr);
    size_t totalSize   = sizeof(Pre) + sizeof(Hdr) + payloadSize;

    std::vector<uint8_t> buf(totalSize, 0);

    // Fill PreMessage
    Pre* pre           = reinterpret_cast<Pre*>(buf.data());
    pre->magic         = magic;
    pre->version       = 1;
    pre->flags         = 0x0001;
    pre->record_count  = 2;
    pre->record_size   = static_cast<uint32_t>(payloadSize / 2);
    pre->payload_bytes = payloadSize;

    // Fill MessageHeader (sits directly after PreMessage)
    Hdr* hdr          = reinterpret_cast<Hdr*>(buf.data() + sizeof(Pre));
    hdr->sequence_id  = sequence_id;
    hdr->source_id    = source_id;
    hdr->timestamp_ns = 0x0000000006F818A1; // fake timestamp
    hdr->encoding     = 0;
    hdr->checksum     = 0xBEEF;

    // Fill payload (sits directly after MessageHeader)
    std::memcpy(buf.data() + sizeof(Pre) + sizeof(Hdr), payloadStr, payloadSize);

    return buf;
};

struct Emit { int type; uint32_t magic; uint32_t seq; uint32_t src; const char* payload; };
Emit emits[] = {
