// Left column = hex values. Right column = ASCII (. for non-printable).
//
//  0000  ef be ad de 01 00 01 00 02 00 00 00 …  | …………….
//
void dumpBuffer(const uint8_t* buf, size_t nbytes) {
std::cout << “[DUMP] Raw buffer — “ << nbytes << “ bytes\n”;
std::cout << std::hex << std::setfill(‘0’);

