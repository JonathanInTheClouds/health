// –– Message types —————————————–

enum class MessageType : int {
Telemetry  = 1,
Diagnostic = 2,
Event      = 3,
Payload    = 4
};

inline std::string messageTypeName(int type) {
switch (static_cast<MessageType>(type)) {
case MessageType::Telemetry:  return “Telemetry”;
case MessageType::Diagnostic: return “Diagnostic”;
case MessageType::Event:      return “Event”;
case MessageType::Payload:    return “Payload”;
default:                      return “Unknown”;
}
}

// –– Structs ———————————————–

// Renamed from MessageHeader — sits at offset 0 in the buffer
#pragma pack(push, 1)
struct PreMessage {
uint32_t magic;
uint16_t version;
uint16_t flags;
uint32_t record_count;
uint32_t record_size;
uint64_t payload_bytes;
};
#pragma pack(pop)

// New MessageHeader — sits directly after PreMessage in the buffer
#pragma pack(push, 1)
struct MessageHeader {
uint32_t sequence_id;   // monotonically increasing message counter
uint32_t source_id;     // identifies which subsystem sent this
uint64_t timestamp_ns;  // nanosecond timestamp
uint16_t encoding;      // 0=raw  1=compressed  2=encrypted
uint16_t checksum;      // simple integrity check
};
#pragma pack(pop)

// What we store per captured message
struct CapturedMessage {
int                  messageType;
PreMessage           pre;     // parsed from offset 0
MessageHeader        header;  // parsed from offset sizeof(PreMessage)
std::vector<uint8_t> payload; // deep copy — everything after both headers
};

