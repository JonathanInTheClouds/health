// Pack static array of PayloadBody into a sequence<octet>
OctetSeq packBodies(const PayloadBody* bodies, size_t count) {
    const size_t totalBytes = count * sizeof(PayloadBody);
    OctetSeq seq(totalBytes);

    for (size_t i = 0; i < count; ++i) {
        std::memcpy(
            seq.data() + (i * sizeof(PayloadBody)),
            &bodies[i],
            sizeof(PayloadBody)
        );
    }

    return seq;
}

// Unpack sequence<octet> back into list of PayloadBody
std::vector<PayloadBody> unpackBodies(const OctetSeq& seq) {
    const size_t count = seq.size() / sizeof(PayloadBody);
    std::vector<PayloadBody> bodies(count);

    for (size_t i = 0; i < count; ++i) {
        std::memcpy(
            &bodies[i],
            seq.data() + (i * sizeof(PayloadBody)),
            sizeof(PayloadBody)
        );
    }

    return bodies;
}
